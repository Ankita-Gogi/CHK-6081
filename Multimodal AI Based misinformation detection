            "viral truth", "government hiding", "secret revealed", "urgent warning", "forward this message",
            "they dont want you to know", "hidden truth", "magic remedy", "exclusive leaked", "banned information",
            "must watch", "breaking secret", "big conspiracy", "massive coverup", "exposed truth", "secret formula",
            "instant cure", "guaranteed cure", "miracle treatment", "no doctor needed", "ancient remedy",
            "magic medicine", "free money trick", "secret hack", "unknown method", "life changing trick",
            "one weird trick", "banned cure", "hidden medicine", "suppressed research", "elite secret",
            "dangerous truth", "classified file", "forbidden knowledge", "top secret", "secret document",
            "exposed document", "viral message", "viral claim", "shocking truth", "unbelievable news",
            "must read", "read before deleted", "urgent alert", "final warning", "last chance",
            "send to everyone", "share with friends", "spread quickly", "viral news", "danger alert",
            "unknown cure", "lost secret", "mystery cure", "mysterious discovery", "hidden formula",
            "exposed scientist", "government lie", "media lie", "mainstream lie", "fake media",
            "dangerous conspiracy", "secret vaccine", "hidden vaccine", "forbidden treatment", "miracle drug",
            "shocking discovery", "top secret discovery", "mystery virus", "hidden disease", "secret disease",
            "unknown illness", "secret government lab", "dangerous experiment", "illegal research",
            "dark secret", "hidden agenda", "powerful secret", "unknown scientist", "mysterious expert",
            "viral conspiracy", "big secret", "unknown fact", "mystery solution", "exposed lie",
            "breaking conspiracy", "forbidden science", "hidden cure", "unknown remedy", "secret remedy",
            "miracle plant", "miracle herb", "ancient cure", "lost medicine", "mystery medicine",
            "magic pill", "super cure", "instant medicine", "fast cure", "secret therapy",
            "secret chemical", "hidden compound", "danger chemical", "mystery formula", "unknown formula",
            "banned substance", "miracle supplement", "miracle vitamin", "magic powder", "instant health",
            "overnight cure", "overnight success", "secret trick", "viral trick", "money trick",
            "guaranteed profit", "fast profit", "instant income", "secret investment", "hidden market",
            "unknown market", "mystery investment", "secret trading", "hidden stock", "unknown crypto",
            "secret crypto", "viral crypto", "guaranteed crypto", "instant crypto", "fast crypto",
            "unknown billionaire secret", "secret wealth trick", "hidden money method", "instant millionaire",
            "overnight millionaire", "secret millionaire trick", "magic investment", "fast money",
            "guaranteed income", "secret profit", "unknown profit", "viral profit", "instant profit",
            "mystery income", "hidden income", "dangerous investment", "secret economy", "fake economy",
            "hidden economy", "secret banking", "unknown banking", "mystery bank", "secret fund",
            "hidden fund", "secret account", "unknown account", "mystery transaction", "secret payment",
            "hidden payment", "mysterious transfer", "unknown transfer", "viral transfer", "secret leak",
            "massive leak", "huge leak", "danger leak", "classified leak", "unknown leak",
            "viral scandal", "secret scandal", "hidden scandal", "massive scandal", "government scandal",
            "political scandal", "media scandal", "corporate scandal", "financial scandal", "banking scandal",
            "health scandal", "science scandal", "medical scandal", "vaccine scandal", "drug scandal",
            "unknown danger", "hidden danger", "secret danger", "viral danger", "danger message",
            "urgent message", "emergency message", "secret emergency", "hidden emergency", "viral emergency",
            "unknown threat", "secret threat", "hidden threat", "danger threat", "viral threat"

        ];

        let trustedWords = [

            "according to research", "scientific study", "data analysis", "official report",
            "government report", "research published", "scientists confirmed", "peer reviewed",
            "clinical trial", "fact checked", "verified source", "investigation report",
            "medical journal", "researchers found", "data collected", "survey results",
            "university research", "laboratory tested", "evidence based", "published study",
