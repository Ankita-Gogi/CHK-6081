<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>AI Misinformation Detection</title>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body {
            background: #020617;
            color: white;
            overflow: hidden;
        }

        /* Background animation */

        .bg {
            position: fixed;
            width: 100%;
            height: 100%;
            z-index: -1;
            overflow: hidden;
        }

        .circle {
            position: absolute;
            width: 120px;
            height: 120px;
            background: rgba(56, 189, 248, 0.08);
            border-radius: 50%;
            animation: float 18s infinite;
        }

        @keyframes float {

            0% {
                transform: translateY(0) rotate(0)
            }

            50% {
                transform: translateY(-200px) rotate(180deg)
            }

            100% {
                transform: translateY(0) rotate(360deg)
            }

        }

        .c1 {
            top: 10%;
            left: 20%
        }

        .c2 {
            top: 70%;
            left: 80%
        }

        .c3 {
            top: 40%;
            left: 50%
        }

        .c4 {
            top: 80%;
            left: 10%
        }

        .c5 {
            top: 25%;
            left: 75%
        }

        /* Main Container */

        .container {
            width: 90%;
            max-width: 1000px;
            margin: auto;
            margin-top: 60px;
            padding: 30px;
            background: rgba(255, 255, 255, 0.07);
            backdrop-filter: blur(15px);
            border-radius: 15px;
            box-shadow: 0 0 25px rgba(56, 189, 248, 0.3);
        }

        h1 {
            text-align: center;
            color: #38bdf8;
            margin-bottom: 10px;
        }

        .subtitle {
            text-align: center;
            margin-bottom: 25px;
            opacity: 0.8;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
        }

        .card {
            background: rgba(255, 255, 255, 0.05);
            padding: 20px;
            border-radius: 10px;
            transition: .3s;
        }

        .card:hover {
            transform: translateY(-6px);
            box-shadow: 0 0 15px #38bdf8;
        }

        textarea {
            width: 100%;
            height: 120px;
            margin-top: 10px;
            border-radius: 8px;
            border: none;
            padding: 10px;
        }

        .btn {
            margin-top: 10px;
            padding: 10px;
            border: none;
            border-radius: 6px;
            background: #38bdf8;
            cursor: pointer;
        }

        .detect {
            display: block;
            margin: 25px auto;
            padding: 14px 30px;
            background: #22c55e;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-size: 16px;
        }

        .detect:hover {
            transform: scale(1.05);
        }

        .result {
            text-align: center;
            padding: 20px;
            background: rgba(0, 0, 0, 0.4);
            border-radius: 10px;
            font-size: 18px;
        }

        .scoreBar {
            width: 100%;
            height: 15px;
            background: #111;
            border-radius: 10px;
            margin-top: 10px;
            overflow: hidden;
        }

        .scoreFill {
            height: 100%;
            width: 0%;
            background: red;
            transition: 1s;
        }

        img {
            margin-top: 10px;
            border-radius: 10px;
            width: 100%;
            display: none;
        }
    </style>

</head>

<body>

    <div class="bg">

        <div class="circle c1"></div>
        <div class="circle c2"></div>
        <div class="circle c3"></div>
        <div class="circle c4"></div>
        <div class="circle c5"></div>

    </div>

    <div class="container">

        <h1>Multimodal AI Misinformation Detection</h1>
        <p class="subtitle">Analyze News Articles and Images using AI Logic</p>

        <div class="grid">

            <div class="card">

                <h3>Insert Image</h3>

                <input type="file" id="imageInput" accept="image/*">

                <button class="btn" onclick="previewImage()">Preview</button>

                <img id="imagePreview">

            </div>

            <div class="card">

                <h3>Insert Article</h3>

                <textarea id="articleText" placeholder="Paste news article here..."></textarea>

            </div>

        </div>

        <button class="detect" onclick="detect()">Analyze Misinformation</button>

        <div class="result" id="resultBox">

            AI Risk Score will appear here

            <div class="scoreBar">
                <div class="scoreFill" id="scoreFill"></div>
            </div>

        </div>

    </div>

    <script>

        let fakeWords = [

