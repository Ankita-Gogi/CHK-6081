            "global research report", "international study", "cross country study", "global dataset",
            "international journal", "research collaboration", "scientific collaboration",
            "academic collaboration", "peer collaboration", "university collaboration",
            "research partnership", "scientific partnership", "international research network",
            "research consortium", "global science report", "international medical journal",
            "public science database", "research archive", "scientific archive", "open data source",
            "trusted dataset", "public dataset", "open research", "transparent research"

        ];
        function previewImage() {

            let file = document.getElementById("imageInput").files[0];

            if (file) {

                let img = document.getElementById("imagePreview");
                img.src = URL.createObjectURL(file);
                img.style.display = "block";

            }

        }

        function detect() {

            let text = document.getElementById("articleText").value.toLowerCase();
            let image = document.getElementById("imageInput").files[0];

            let fakeScore = 0;
            let realScore = 0;

            fakeWords.forEach(w => {
                if (text.includes(w)) { fakeScore += 10 }
            });

            trustedWords.forEach(w => {
                if (text.includes(w)) { realScore += 12 }
            });

            if (text.length > 200) { realScore += 10 }
            else if (text.length > 0) { fakeScore += 5 }

            let imageResult = "No Image";

            if (image) {

                let size = image.size / (1024 * 1024);
                let name = image.name.toLowerCase();

                if (size < 0.1 || name.includes("ai") || name.includes("fake")) {

                    fakeScore += 15
                    imageResult = "❌ Image looks AI Generated"

                } else {

                    realScore += 10
                    imageResult = "✅ Image looks Real"

                }

            }

            let total = fakeScore + realScore;
            let risk = Math.round((fakeScore / Math.max(total, 1)) * 100);

            let textResult = "";

            if (fakeScore > realScore) {
                textResult = "❌ Text appears Fake"
            } else if (text.length > 0) {
                textResult = "✅ Text appears Reliable"
            } else {
                textResult = "No Text Provided"
            }

            document.getElementById("resultBox").innerHTML =

                `<b>${textResult}</b><br><br>
<b>${imageResult}</b><br><br>
AI Fake Risk Score: ${risk}%

<div class="scoreBar">
<div class="scoreFill" id="scoreFill"></div>
</div>`;

            setTimeout(() => {
                document.getElementById("scoreFill").style.width = risk + "%";
            }, 100)

        }

    </script>

</body>

</html>
